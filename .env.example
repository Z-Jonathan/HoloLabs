# Holo waitlist — Supabase credentials
#
# The site builds and runs WITHOUT these (the waitlist falls back to a
# server-side "demo mode" that logs submissions and returns success).
# Set these to persist real waitlist signups.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (server-only — NEVER expose to the client / browser).
# Found in: Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- Holo Studio (/studio) ---
# Anthropic API key for Holo's conversational replies (server-only).
# Without it, /studio falls back to simple canned demo replies.
ANTHROPIC_API_KEY=
